---
// src/components/ImpactScroll.astro
---

<section class="py-24 px-6 lg:px-12 max-w-7xl mx-auto border-t border-bertu-black/5">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
    
    <div class="lg:sticky lg:top-32 space-y-8">
      <div class="inline-block px-4 py-1.5 bg-bertu-orange/10 rounded-full">
        <span class="text-bertu-orange font-bold text-[10px] tracking-[0.2em]">Our Impact</span>
      </div>
      <h2 class="text-5xl md:text-6xl font-display leading-tight tracking-tighter">
        Stories of <br/> <span class="text-bertu-orange">Strength.</span>
      </h2>
      <p class="text-lg text-bertu-black/60 font-sans max-w-md leading-relaxed">
         Explore how our campaigns have directly impacted the lives of people.
      </p>
      <div class="pt-8">
        <div class="text-xs tracking-widest font-bold opacity-30 mb-4">Scroll to explore</div>
        <div class="w-px h-16 bg-bertu-black/10 origin-top animate-scale-y"></div>
      </div>
    </div>

    <div class="space-y-32">
      
      <div class="impact-item group">
        <div 
          class="relative aspect-video rounded-3xl overflow-hidden bg-bertu-black cursor-pointer video-trigger"
          data-video-id="nrclo9eXJ4E" 
        >
          <img src="https://img.youtube.com/vi/nrclo9eXJ4E/maxresdefault.jpg" class="w-full h-full object-cover opacity-70 group-hover:scale-105 transition-transform duration-700" alt="Zene's Story of Hope" />
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-20 h-20 bg-bertu-orange text-white rounded-full flex items-center justify-center scale-90 group-hover:scale-100 transition-transform shadow-xl">
              <i class="fa-solid fa-play text-2xl ml-1"></i>
            </div>
          </div>
        </div>
        <div class="mt-8 space-y-4">
          <h3 class="text-3xl font-display tracking-tighter">From Tragedy to a New Life</h3>
          <p class="text-bertu-black/70 font-sans leading-relaxed">
            After surviving a life-threatening ordeal, Zene was lifted from despair by a community that refused to look away. With your support, she has moved <strong>"from death to life,"</strong> opening a new business to secure a future for her and her child.
          </p>
        </div>
      </div>

      <div class="impact-item group">
        <div 
          class="relative aspect-video rounded-3xl overflow-hidden bg-bertu-black cursor-pointer video-trigger"
          data-video-id="ablAPvWSNiU"
        >
          <img src="https://img.youtube.com/vi/ablAPvWSNiU/maxresdefault.jpg" class="w-full h-full object-cover opacity-70 group-hover:scale-105 transition-transform duration-700" alt="Resilience Stories" />
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-20 h-20 bg-bertu-orange text-white rounded-full flex items-center justify-center scale-90 group-hover:scale-100 transition-transform shadow-xl">
              <i class="fa-solid fa-play text-2xl ml-1"></i>
            </div>
          </div>
        </div>
        <div class="mt-8 space-y-4">
          <h3 class="text-3xl font-display tracking-tighter">Resilience & Hope</h3>
          <p class="text-bertu-black/70 font-sans leading-relaxed">Sharing deeply personal stories of overcoming challenges, designed to inspire the youth and honor our collective journey.</p>
        </div>
      </div>


      <div class="impact-item group">
        <div 
          class="relative aspect-video rounded-3xl overflow-hidden bg-bertu-black cursor-pointer video-trigger"
          data-video-id="WeteoqDtULE"
        >
          <img src="https://img.youtube.com/vi/WeteoqDtULE/maxresdefault.jpg" class="w-full h-full object-cover opacity-70 group-hover:scale-105 transition-transform duration-700" alt="Support for a Hero's Mother" />
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-20 h-20 bg-bertu-orange text-white rounded-full flex items-center justify-center scale-90 group-hover:scale-100 transition-transform shadow-xl">
              <i class="fa-solid fa-play text-2xl ml-1"></i>
            </div>
          </div>
        </div>
        <div class="mt-8 space-y-4">
          <h3 class="text-3xl font-display tracking-tighter">Honoring a Hero's Sacrifice</h3>
          <p class="text-bertu-black/70 font-sans leading-relaxed">
            After her only son fell in service to his country, this mother was left to fight advanced cancer without a support system. We are mobilizing the community to ensure the mother of a fallen soldier is never left to suffer alone.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<div id="video-modal" class="fixed inset-0 z-[200] bg-bertu-black/90 invisible opacity-0 transition-all duration-500 flex items-center justify-center p-8 md:p-24">
  
  <button id="close-video" class="absolute top-6 right-6 md:top-10 md:right-10 text-white hover:text-bertu-orange transition-colors z-[250] p-3 bg-white/10 backdrop-blur-md rounded-full">
    <i class="fa-solid fa-xmark text-2xl md:text-3xl"></i>
  </button>
  
  <div class="w-full max-w-4xl aspect-video bg-black rounded-2xl overflow-hidden shadow-2xl relative z-[210]">
    <iframe 
      id="modal-iframe"
      class="w-full h-full" 
      src="" 
      title="YouTube video player" 
      frameborder="0" 
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
      allowfullscreen>
    </iframe>
  </div>

  <div id="modal-backdrop" class="absolute inset-0 cursor-pointer z-[205]"></div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const modal = document.getElementById('video-modal');
    const iframe = document.getElementById('modal-iframe') as HTMLIFrameElement;
    const triggers = document.querySelectorAll('.video-trigger');
    const closeBtn = document.getElementById('close-video');
    const backdrop = document.getElementById('modal-backdrop');

    const openVideo = (id: string) => {
      if (!modal || !iframe) return;
      iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`;
      modal.classList.remove('invisible', 'opacity-0');
      document.body.style.overflow = 'hidden';
    };

    const closeVideo = () => {
      if (!modal || !iframe) return;
      modal.classList.add('invisible', 'opacity-0');
      setTimeout(() => { iframe.src = ""; }, 500); 
      document.body.style.overflow = '';
    };

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const videoId = trigger.getAttribute('data-video-id');
        if (videoId) openVideo(videoId);
      });
    });

    closeBtn?.addEventListener('click', closeVideo);
    backdrop?.addEventListener('click', closeVideo);
    
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeVideo();
    });
  });
</script>

<style>
  @keyframes scale-y {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }
  .animate-scale-y {
    animation: scale-y 3s ease-in-out infinite;
  }
</style>
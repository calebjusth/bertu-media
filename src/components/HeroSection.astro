---
// src/components/Hero.astro
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden px-6 mt-20 lg:px-12">
  <div class="max-w-7xl mx-auto w-full grid lg:grid-cols-12 gap-12 items-center">
    
    <div class="lg:col-span-7 z-10">
      
      <h1 class="heading-hero mb-8 font-display font-black text-[12vw] md:text-[8rem] leading-[0.9] uppercase italic tracking-tighter">
        <div class="line-mask">
          <span class="reveal-text">Strength</span>
        </div>
        <div class="line-mask">
          <span class="reveal-text text-bertu-orange">Through</span>
        </div>
        <div class="line-mask">
          <span class="reveal-text">Stories.</span>
        </div>
      </h1>
      
      <p class="text-xl md:text-2xl text-bertu-black/70 max-w-xl mb-12 font-sans leading-relaxed">
        We build media that strengthens communities and protects our legacy.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/AboutUs" class="btn-outline px-8 py-4 border-2 border-bertu-black text-bertu-black rounded-full font-bold inline-flex items-center justify-center hover:bg-bertu-black hover:text-white transition-colors">
          Our Story
        </a>
      </div>
    </div>

    <div class="lg:col-span-5 relative group">
      <div class="relative aspect-[4/5] overflow-hidden rounded-2xl shadow-2xl shadow-bertu-black/10">
        <img 
          src={`${import.meta.env.BASE_URL}/hero.png`} 
          alt="Youth Empowerment Media" 
          class="w-full h-full object-cover grayscale transition-all duration-1000 "
        />
      </div>
      <div class="absolute -z-10 top-20 -right-20 w-64 h-64 bg-bertu-orange/5 rounded-full blur-3xl"></div>
    </div>
  </div>
</section>

<style>
  /* The Container that hides the text */
  .line-mask {
    overflow: hidden;
    display: block;
    height: auto;
  }

  /* The actual text that slides up */
  .reveal-text {
    display: inline-block;
    transform: translateY(110%); /* Start completely hidden below the mask */
    transition: transform 1.2s cubic-bezier(0.85, 0, 0.15, 1);
    will-change: transform;
  }

  /* When the 'active' class is added via JS */
  .heading-hero.active .reveal-text {
    transform: translateY(0);
  }

  /* Stagger the lines so they appear one after another */
  .line-mask:nth-child(2) .reveal-text {
    transition-delay: 0.1s;
  }
  .line-mask:nth-child(3) .reveal-text {
    transition-delay: 0.2s;
  }
</style>

<script>
  // Function to handle the animation trigger
  function initReveal() {
    const observerOptions = {
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          // Once it's animated, we don't need to observe it anymore
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    const target = document.querySelector('.heading-hero');
    if (target) observer.observe(target);
  }

  // Runs on initial load
  initReveal();

  // Runs every time Astro View Transitions swaps pages
  document.addEventListener('astro:after-swap', initReveal);
</script>
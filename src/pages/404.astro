---

import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Page Not Found">
  <main class="bg-bertu-orange min-h-screen flex items-center justify-center px-6 relative overflow-hidden">
    


    <div class="max-w-4xl w-full text-center z-10">
      <h1 class="font-display text-[25vw] md:text-[15rem] font-black text-white leading-[0.8] tracking-tighter uppercase mb-4 italic">
        404
      </h1>

      <div class="space-y-6">
        <h2 class="font-display text-4xl md:text-6xl font-bold text-bertu-black uppercase tracking-tighter">
            Page Not Found.
        </h2>
        <p class="text-white text-xl md:text-2xl font-sans font-medium max-w-xl mx-auto leading-tight">
            It looks like something's gone wrong. This story hasn't been written yet, or the link has moved.
        </p>
      </div>

      <div class="mt-12">
        <a 
          href="/" 
          class="inline-block bg-bertu-black text-white hover:bg-bertu-cream hover:text-bertu-orange px-10 py-5 rounded-xl font-bold uppercase tracking-widest transition-all  active:scale-95"
        >
          Return to Homepage
        </a>
      </div>
    </div>


  </main>
</Layout>

<style>
  /* Custom easing for the button and text */
  h1, h2 {
    font-stretch: condensed;
  }

  /* Subtle entrance animation so the page doesn't just "pop" in */
  main {
    animation: fadeIn 0.6s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Making the 404 text feel slightly cinematic */

</style>
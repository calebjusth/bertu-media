---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="The misson | Our Story   | Bertu Media">
  <main class="bg-bertu-cream min-h-screen pt-32">
    
    <section class="px-6 lg:px-12 max-w-7xl mx-auto mb-32">
      <div class="max-w-5xl">
      <h1 class="text-[12vw] md:text-[9vw] font-display font-black leading-[0.85] tracking-tighter text-bertu-black uppercase mb-12">
          From Vision <br/> 
          <span class="flex items-center gap-4">
            to
            <div class="w-[25vw] h-[12vw] md:w-[15vw] md:h-[8vw] bg-bertu-orange rounded-full overflow-hidden shadow-2xl">
                <img src="https://images.unsplash.com/photo-1492691527719-9d1e07e534b4?auto=format&fit=crop&q=80&w=800" class="w-full h-full object-cover grayscale" alt="Cinema Camera" />
            </div>
            Legacy.
          </span>
        </h1>
        <div class="grid md:grid-cols-2 gap-12 items-start">
            <p class="text-2xl md:text-3xl font-sans font-medium text-bertu-black leading-tight">
                Bertu Media began as a response to a disappearing history. We saw stories fading and voices being muffled, so we built a sanctuary for truth.
            </p>
            <p class="text-lg text-bertu-black/60 leading-relaxed">
                Founded on the principle of "Bertu" (Stay Strong), we bridge the gap between cinematic excellence and humanitarian heart. What started as a small media collective has grown into a powerhouse for social change, using the lens to not just watch the world, but to fix it.
            </p>
        </div>
      </div>
    </section>

    <section class="mb-40 px-6 lg:px-12 max-w-7xl mx-auto">
        <div class="border-t-4 border-bertu-black pt-8 mb-16">
            <h2 class="text-5xl md:text-7xl font-display font-black uppercase tracking-tighter">What We Do</h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="bg-bertu-orange p-10 rounded-[40px] flex flex-col justify-between min-h-[400px] text-white group hover:bg-bertu-black transition-colors duration-500">
                <div>
                    <i class="fa-solid fa-hand-holding-heart text-4xl mb-6"></i>
                    <h3 class="text-4xl font-display font-bold uppercase mb-4">Charity & Impact</h3>
                    <p class="text-white/80 leading-relaxed">This is our heartbeat. We use our platform to raise funds, awareness, and hope for the most vulnerable communities in Ethiopia and beyond.</p>
                </div>
                <div class="font-bold uppercase tracking-widest text-xs pt-8 border-t border-white/20">Primary Focus</div>
            </div>

            <div class="bg-white border-2 border-bertu-black/5 p-10 rounded-[40px] flex flex-col justify-between min-h-[400px] group hover:border-bertu-orange transition-all duration-500">
                <div>
                    <i class="fa-solid fa-film text-4xl mb-6 text-bertu-orange"></i>
                    <h3 class="text-4xl font-display font-bold uppercase mb-4 text-bertu-black">Creative Studio</h3>
                    <p class="text-bertu-black/60 leading-relaxed">Producing cinematic content that inspires. From documentaries to short films, we tell stories that matter.</p>
                </div>
                <div class="font-bold uppercase tracking-widest text-xs pt-8 border-t border-bertu-black/5">Entertainment</div>
            </div>

            <div class="bg-white border-2 border-bertu-black/5 p-10 rounded-[40px] flex flex-col justify-between min-h-[400px] group hover:border-bertu-orange transition-all duration-500">
                <div>
                    <i class="fa-solid fa-newspaper text-4xl mb-6 text-bertu-orange"></i>
                    <h3 class="text-4xl font-display font-bold uppercase mb-4 text-bertu-black">Newsroom</h3>
                    <p class="text-bertu-black/60 leading-relaxed">Providing a lens on global events with a focus on community resilience and authentic reporting.</p>
                </div>
                <div class="font-bold uppercase tracking-widest text-xs pt-8 border-t border-bertu-black/5">Information</div>
            </div>
        </div>
    </section>

    <section class="bg-bertu-black py-32 text-white overflow-hidden mb-40">
        <div class="max-w-7xl mx-auto px-6 lg:px-12">
            <div class="grid lg:grid-cols-2 gap-24 items-center">
                <div class="relative">
                    <div class="absolute -top-20 -left-20 text-[20rem] font-display font-black text-white/5 select-none">"</div>
                    <h2 class="text-6xl md:text-8xl font-display font-black uppercase leading-none tracking-tighter mb-8 relative z-10">
                        Our <span class="text-bertu-orange">Pulse.</span>
                    </h2>
                    <div class="space-y-12">
                        <div class="flex gap-6">
                            <span class="text-bertu-orange font-display text-4xl font-bold italic">01</span>
                            <div>
                                <h4 class="text-2xl font-bold uppercase mb-2">Integrity</h4>
                                <p class="text-white/50 max-w-sm">We tell the truth, even when it's heavy. Especially when it's heavy.</p>
                            </div>
                        </div>
                        <div class="flex gap-6">
                            <span class="text-bertu-orange font-display text-4xl font-bold italic">02</span>
                            <div>
                                <h4 class="text-2xl font-bold uppercase mb-2">Excellence</h4>
                                <p class="text-white/50 max-w-sm">We hold ourselves to the highest standards in storytelling and production.</p>
                            </div>
                        </div>
                        <div class="flex gap-6">
                            <span class="text-bertu-orange font-display text-4xl font-bold italic">03</span>
                            <div>
                                <h4 class="text-2xl font-bold uppercase mb-2">Community</h4>
                                <p class="text-white/50 max-w-sm">We don't just film people; we build alongside them.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="relative">
                    <div class="aspect-square bg-bertu-orange rounded-[60px] overflow-hidden">
                        <img src="./hero.png" class="w-full h-full object-cover mix-blend-multiply opacity-80" alt="Camera lens" />
                    </div>
                    <div class="absolute inset-0 border-2 border-white/20 rounded-[60px] -rotate-3 -z-10"></div>
                </div>
            </div>
        </div>
    </section>

    <section class="px-6 lg:px-12 max-w-7xl mx-auto mb-40">
      <div class="text-center mb-20">
        <h2 class="text-6xl md:text-8xl font-display font-black uppercase tracking-tighter">The Humans Behind <br/> <span class="text-bertu-orange underline decoration-8">The Lens</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group">
          <div class="aspect-[3/4] overflow-hidden rounded-[30px] mb-6 bg-bertu-black relative">
            <img 
              src="./derje.png" 
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" 
              alt="Founder"
            />
            <div class="absolute bottom-6 left-6 right-6 p-6 bg-white/10 backdrop-blur-md rounded-2xl border border-white/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                <p class="text-white text-sm font-medium">"Every story is a seed for a better future."</p>
            </div>
          </div>
          <h3 class="text-3xl font-display font-bold uppercase mb-1">Dereje Yenewelegn</h3>
          <p class="text-bertu-orange font-bold uppercase tracking-widest text-xs">Founding Member</p>
        </div>

        <div class="group lg:mt-20">
          <div class="aspect-[3/4] overflow-hidden rounded-[30px] mb-6 bg-bertu-black relative">
            <img 
              src="./eliyas.png" 
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" 
              alt="Producer"
            />
          </div>
          <h3 class="text-3xl font-display font-bold uppercase mb-1">Elias Kefle</h3>
          <p class="text-bertu-orange font-bold uppercase tracking-widest text-xs">Founding Member</p>
        </div>

        <div class="group">
          <div class="aspect-[3/4] overflow-hidden rounded-[30px] mb-6 bg-bertu-black relative">
            <img 
              src="./bini.png" 
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" 
              alt="Cinematographer"
            />
          </div>
          <h3 class="text-3xl font-display font-bold uppercase mb-1">Biniyam Asefaw</h3>
          <p class="text-bertu-orange font-bold uppercase tracking-widest text-xs">Founding Member</p>
        </div>
      </div>
    </section>

    <section class="bg-bertu-orange py-32 px-6 lg:px-12 rounded-t-[60px] md:rounded-t-[100px]">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-start">
          <div>
            <h2 class="text-[10vw] font-display font-black text-white leading-[0.85] tracking-tighter uppercase mb-12">
              Stay <br/> Strong.
            </h2>
            <div class="space-y-10">
              <div class="group">
                <p class="text-white/60 uppercase text-xs tracking-widest font-bold mb-4">Partner with us</p>
                <a href="mailto:hello@bertumedia.com" class="text-3xl md:text-5xl font-display font-bold text-white hover:bg-white hover:text-bertu-orange px-4 py-2 -ml-4 rounded-xl transition-all inline-block">
                  hello@bertumedia.com
                </a>
                <br>
                <a href="tel:+25192366 8226" class="text-3xl md:text-5xl font-display font-bold text-white hover:bg-white hover:text-bertu-orange px-4 py-2 -ml-4 rounded-xl transition-all inline-block">
                  +251 92 366 8226
                </a>
              </div>
              <div class="flex gap-8 items-center text-white">
                <a  class="text-4xl hover:text-bertu-black transition-colors"><i class="fa-brands fa-instagram"></i></a>
                <a href="https://www.youtube.com/@bertumedia1" target="_blank" class="text-4xl hover:text-bertu-black transition-colors"><i class="fa-brands fa-youtube"></i></a>
                <a  class="text-4xl hover:text-bertu-black transition-colors"><i class="fa-brands fa-linkedin"></i></a>
              </div>
            </div>
          </div>

          <div class="bg-bertu-black p-12 rounded-[50px] relative overflow-hidden">
            <div class="relative z-10">
                <h3 class="text-3xl font-display font-bold text-white mb-6 uppercase">Become a Story Keeper</h3>
                <p class="text-white/60 text-lg leading-relaxed mb-10">
                  Whether you are a donor, a creative professional, or a volunteer, there is a place for you in our mission. Let's make history together.
                </p>
                <button id="donate-button" class="bg-bertu-orange text-white px-10 py-5 rounded-full font-bold uppercase tracking-widest hover:bg-white hover:text-bertu-orange transition-all w-full md:w-auto">
                    Support Our Mission
                </button>
            </div>
            <div class="absolute -bottom-20 -right-20 w-64 h-64 bg-bertu-orange rounded-full"></div>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  h1, h2, h3 {
    font-stretch: condensed;
  }
</style>